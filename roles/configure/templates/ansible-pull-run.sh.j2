#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $0 BRANCH:PLAYBOOK[:DOWNSTREAM_BRANCH] [--force]" >&2
}

input="${1:-}"
skip_unchanged="{{ ansible_pull_skip_unchanged | ternary('true', 'false') }}"

if [[ -z "$input" ]] || [[ $# -gt 2 ]]; then
  usage
  exit 2
fi

if [[ "${2:-}" == "--force" ]]; then
  skip_unchanged="false"
elif [[ -n "${2:-}" ]]; then
  usage
  exit 2
fi

IFS=: read -r branch playbook downstream_branch extra <<<"$input"
downstream_branch="${downstream_branch:-$branch}"

if [[ -n "${extra:-}" ]] || [[ -z "$branch" ]] || [[ -z "$playbook" ]]; then
  usage
  exit 2
fi

if [[ ! "$branch" =~ ^[-A-Za-z0-9._/]+$ ]] || [[ "$branch" == .* ]] || [[ "$branch" == */.* ]] || [[ "$branch" == *..* ]]; then
  echo "Invalid branch name: $branch" >&2
  exit 2
fi

if [[ ! "$downstream_branch" =~ ^[-A-Za-z0-9._/]+$ ]] || [[ "$downstream_branch" == .* ]] || [[ "$downstream_branch" == */.* ]] || [[ "$downstream_branch" == *..* ]]; then
  echo "Invalid downstream branch name: $downstream_branch" >&2
  exit 2
fi

if [[ "$playbook" != playbooks/* ]]; then
  playbook="${playbook%.yml}"
  playbook="${playbook%.yaml}"
  playbook="playbooks/${playbook}.yml"
fi

if [[ ! "$playbook" =~ ^playbooks/[-A-Za-z0-9._/]+\.ya?ml$ ]] || [[ "$playbook" == *..* ]] || [[ "$playbook" == */.* ]]; then
  echo "Invalid playbook path: $playbook" >&2
  exit 2
fi

if [[ "$skip_unchanged" != "true" ]] && [[ "$skip_unchanged" != "false" ]]; then
  echo "Invalid skip_unchanged value: $skip_unchanged" >&2
  exit 2
fi

repo_url="{{ ansible_pull_repo_url }}"
deploy_repo_url="{{ deploy_repo_url }}"
token_file="{{ ansible_pull_secrets_file }}"
state_key="${branch//\//_}.${playbook//\//_}.${downstream_branch//\//_}"
last_commit_file="/var/lib/ansible-pull/last-commit.$state_key"

mkdir -p /var/lib/ansible-pull

exec 9>/run/ansible-pull.lock
flock -n 9 || {
  echo "ansible-pull is already running" >&2
  exit 0
}

remote_commit=""
if [[ "$skip_unchanged" == "true" ]]; then
  remote_commit="$(git ls-remote "$repo_url" "refs/heads/$branch" | awk '{print $1}')"

  if [[ -z "$remote_commit" ]]; then
    echo "Unable to find branch '$branch' in $repo_url" >&2
    exit 1
  fi

  if [[ "$playbook" == "playbooks/deploy.yml" ]]; then
    downstream_commit="$(git ls-remote "$deploy_repo_url" "refs/heads/$downstream_branch" | awk '{print $1}')"

    if [[ -z "$downstream_commit" ]]; then
      echo "Unable to find downstream branch '$downstream_branch' in $deploy_repo_url" >&2
      exit 1
    fi

    remote_commit="$remote_commit.$downstream_commit"
  fi

  last_commit=""
  if [[ -f "$last_commit_file" ]]; then
    last_commit="$(<"$last_commit_file")"
  fi

  if [[ "$remote_commit" == "$last_commit" ]]; then
    echo "No new commits on $branch for $playbook; skipping ansible-pull"
    exit 0
  fi
fi

if [[ -s "$token_file" ]]; then
  export BWS_ACCESS_TOKEN
  BWS_ACCESS_TOKEN="$(sed -n '1p' "$token_file")"
fi

sudo -E ansible-pull \
  -U "$repo_url" \
  -C "$branch" \
  -e "deploy_repo_branch=$downstream_branch" \
  -l "{{ inventory_hostname }}" \
  "$playbook"

if [[ "$skip_unchanged" == "true" ]]; then
  printf '%s\n' "$remote_commit" > "$last_commit_file"
fi
